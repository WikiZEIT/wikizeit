<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "{{ person['@type'] }}",
      "url": "{{ person.url }}",
      "@id": "{{ person['@id'] }}",
      "name": "{{ person.name }}",
      "image": "{{ person.image }}",
      "jobTitle": "{{ person.jobTitle }}",
      "description": "{{ person.description }}",
      "sameAs": [
        {% for link in person.sameAs %}"{{ link }}"{% unless forloop.last %},
        {% endunless %}{% endfor %}
      ]
    },
    {
      "@type": "BlogPosting",
      "datePublished": "{{ date | dateFormat: 'iso' }}",
      "dateModified": "{% if modified %}{{ modified | dateFormat: 'iso' }}{% else %}{{ date | dateFormat: 'iso' }}{% endif %}",
      "publisher": { "@id": "{{ site.url }}/#organization" },
      "author": { "@id": "{{ person['@id'] }}" },
      "headline": "{{ title }}",
      {% if featuredImage %}"image": {
        "@type": "ImageObject",
        "url": "{{ site.url }}{{ featuredImage | url }}"
      },
      {% endif %}"description": "{{ description }}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}#webpage"
      },
      "isPartOf": {
        "@id": "{{ site.url }}{{ page.url }}#webpage"
      }
    },
    {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}#webpage",
      "url": "{{ site.url }}{{ page.url }}",
      "isPartOf": { "@id": "{{ site.url }}/#blog" },
      "mainEntity": { "@id": "{{ site.url }}{{ page.url }}" }
    },
    {
      "@type": "Blog",
      "@id": "{{ site.url }}/#blog",
      "name": "{{ site.title }} Blog",
      "url": "{{ site.url }}/blog/",
      "description": "{{ site.description }}",
      "isPartOf": { "@id": "{{ site.url }}/" },
      "inLanguage": "pl"
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.url }}/#website",
      "url": "{{ site.url }}/",
      "name": "{{ site.title }}",
      "description": "{{ site.description }}",
      "inLanguage": "{{ site.language }}",
      "publisher": { "@id": "{{ site.url }}/#organization" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "{{ site.url }}{{ page.url }}#breadcrumbs",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": "{{ site.url }}/",
          "name": "{{ site.title }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": "{{ site.url }}/blog/",
          "name": "Blog"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": "{{ site.url }}{{ page.url }}",
          "name": "{{ title }}"
        }
      ]
    }{% if faq %},
    {
      "@type": "FAQPage",
      "mainEntity": [
        {% for item in faq %}{
          "@type": "Question",
          "name": {{ item.question | strip | jsonify }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ item.answer | strip | jsonify }}
          }
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }{% endif %}
  ]
}
</script>

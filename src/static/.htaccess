RewriteEngine On

# Protect sensitive files
RewriteRule ^api/subscribers\.db$ - [R=404,L]
RewriteRule ^api/templates/ - [R=404,L]
RewriteRule ^api/lib/ - [R=404,L]
RewriteRule ^api/composer\.(json|lock)$ - [R=404,L]
RewriteRule ^api/vendor/ - [R=404,L]
RewriteRule ^api/logs/ - [R=404,L]
RewriteRule ^api/mail/ - [R=404,L]

RewriteRule ^szkolenia/(.*)$ /wikizeit/oferta/$1 [R=301,L]

RewriteRule blog/nowa-masktka-wikipedii/ /wikizeit/blog/nowa-maskotka-wikipedii/

# Custom 404 — serve via PHP wrapper so the response status is 404, not 200
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /wikizeit/404.php [L]
